# SubtitleExtractor — macOS worker configuration. Copy to .env and edit.

# URL of the SubtitleExtractor API, reachable from THIS machine.
# Use the API host's real address (not localhost unless the API runs here).
API_BASE_URL=http://CHANGE-ME:8080

# Shared worker token — must match INTERNAL_API_TOKEN on the API.
INTERNAL_API_TOKEN=change-me-internal-worker-token

# Worker class — leave as "macos".
WORKER_CLASS=macos

# How often (seconds) to poll the API for new jobs.
WORKER_POLL_INTERVAL=3

# Optional: default OCR backend if the admin hasn't set one.
#   rapidocr     — CPU (default, always available)
#   paddleocr_vl — Apple GPU via MLX (Apple Silicon only)
# The admin can also choose the backend per-worker from the web UI.
# OCR_BACKEND=rapidocr
